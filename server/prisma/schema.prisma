generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mongodb"
  url      = env("DATABASE_URL")
}

model User {
  id       String    @id @default(auto()) @map("_id") @db.ObjectId
  username String    @unique
  password String
  email    String    @unique
  folders  Folder[]
  files    File[]
  notifications Notification[]
  profile  Profile?
}

model Session {
  id        String   @id @map("_id")
  sid       String   @unique
  data      String
  expiresAt DateTime

  @@index([expiresAt])
}

model PasswordResetOtp {
  id             String    @id @default(auto()) @map("_id") @db.ObjectId
  email          String
  otpHash        String
  resetTokenHash String?
  expiresAt      DateTime
  verifiedAt     DateTime?
  usedAt         DateTime?
  createdAt      DateTime  @default(now())

  @@index([email, createdAt])
}

model Folder {
  id                String   @id @default(auto()) @map("_id") @db.ObjectId
  name              String
  userId            String   @db.ObjectId
  user              User     @relation(fields: [userId], references: [id])
  parentId          String?  @db.ObjectId
  parent            Folder?  @relation("FolderToFolder", fields: [parentId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  children          Folder[] @relation("FolderToFolder")
  isStarred         Boolean  @default(false)
  sharedWithUserIds String[] @db.ObjectId
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
  files             File[]
  Shares            Share[]  @relation("FolderShares")

  @@index([userId])
  @@index([parentId])
}

model File {
  id                String   @id @default(auto()) @map("_id") @db.ObjectId
  name              String
  uid               String
  url               String
  size              Int
  folderId          String?  @db.ObjectId
  folder            Folder?  @relation(fields: [folderId], references: [id])
  userId            String   @db.ObjectId
  user              User     @relation(fields: [userId], references: [id])
  isStarred         Boolean  @default(false)
  sharedWithUserIds String[] @db.ObjectId
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  @@index([userId])
  @@index([folderId])
}

model Share {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  folderId  String   @db.ObjectId
  folder    Folder   @relation(fields: [folderId], references: [id], name: "FolderShares")
  expiresAt DateTime
}

model Notification {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  userId    String   @db.ObjectId
  user      User     @relation(fields: [userId], references: [id])
  type      String
  title     String
  message   String
  metadata  Json?
  isRead    Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId, isRead, createdAt])
  @@index([userId, type, createdAt])
}

model ActivityLog {
  id         String   @id @default(auto()) @map("_id") @db.ObjectId
  // who performed the action
  actorId    String   @db.ObjectId
  actorName  String
  // what resource was affected
  itemId     String   @db.ObjectId
  itemType   String   // "file" | "folder"
  // event info
  event      String   // e.g. "shared", "viewed", "uploaded", "downloaded"
  message    String
  createdAt  DateTime @default(now())

  @@index([itemId, itemType, createdAt])
}

model Profile {
  id                    String   @id @default(auto()) @map("_id") @db.ObjectId
  userId                String   @unique @db.ObjectId
  user                  User     @relation(fields: [userId], references: [id])
  firstName             String?
  lastName              String?
  about                 String?
  avatarUrl             String?
  portfolioName         String?
  portfolioLink         String?
  emailNotifications    Boolean?
  desktopNotifications  Boolean?
  sharedActivity        Boolean?
  twoFactorEnabled      Boolean?
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt
  }
